{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/global-hooks/native-session-start.mjs\"",
            "timeout": 30,
            "statusMessage": "⛩ bench: arming native push gate…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/global-hooks/codex-stop-review.mjs\"",
            "timeout": 900,
            "statusMessage": "⛩ bench: reviewing turn…"
          }
        ]
      }
    ]
  }
}
