{
  "description": "peerBench automatic review gates for Claude Code.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/native-session-start.mjs\"",
            "timeout": 30,
            "statusMessage": "⛩ bench: arming native push gate…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/plan-review.mjs\"",
            "statusMessage": "⛩ bench: reviewing plan…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/pre-push-review.mjs\"",
            "timeout": 30,
            "statusMessage": "⛩ bench: arming native push gate…",
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/pre-merge-review.mjs\"",
            "timeout": 150,
            "statusMessage": "⛩ bench: reviewing merge…",
            "if": "Bash(git merge*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/plan-file-review.mjs\"",
            "statusMessage": "⛩ bench: reviewing plan/spec…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/stop-review.mjs\"",
            "timeout": 900,
            "asyncRewake": true,
            "statusMessage": "⛩ bench: reviewing turn…",
            "rewakeMessage": "⛩ bench stop gate found issues in this turn's code changes. Fix them, then stop again to re-review:",
            "rewakeSummary": "⛩ bench stop"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/global-hooks/deep-review-runner.mjs\"",
            "timeout": 4620,
            "asyncRewake": true,
            "statusMessage": "⛩ bench: deep review…",
            "rewakeMessage": "⛩ bench deep review found blocking issues. Address them, then continue:",
            "rewakeSummary": "⛩ bench deep review"
          }
        ]
      }
    ]
  }
}
